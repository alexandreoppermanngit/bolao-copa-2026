# =============================================================
# Bolão Copa 2026 — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com seus valores
# =============================================================

# --- Supabase (https://supabase.com/dashboard/project/_/settings/api) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# A service role NUNCA deve ser exposta ao cliente. Use só em rotas server.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Lista (separada por vírgula) de e-mails de administradores
ADMIN_EMAILS=alexandre.oppermann@gmail.com

# --- API de resultados (opcional) ---
# Football-Data.org (free: 10 req/min). Pegue em https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# --- Cron secret (para proteger /api/recalc disparado por Vercel cron) ---
CRON_SECRET=troque-por-uma-string-aleatoria-grande
